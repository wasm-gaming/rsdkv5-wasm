{
  "name": "@wasm-gaming/rsdkv5-wasm",
  "version": "0.1.0",
  "description": "RSDKv5 (Retro Software Development Kit v5) compiled to WebAssembly, with a JS SDK conforming to the wasm-gaming engine contract. Runs Sonic Mania by loading Data.rsdk at runtime.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wasm-gaming/rsdkv5-wasm.git"
  },
  "bugs": {
    "url": "https://github.com/wasm-gaming/rsdkv5-wasm/issues"
  },
  "homepage": "https://github.com/wasm-gaming/rsdkv5-wasm#readme",
  "type": "module",
  "main": "./dist/rsdkv5/rsdkv5.sdk.js",
  "types": "./dist/rsdkv5/rsdkv5.sdk.d.ts",
  "exports": {
    ".": {
      "types": "./dist/rsdkv5/rsdkv5.sdk.d.ts",
      "import": "./dist/rsdkv5/rsdkv5.sdk.js"
    },
    "./options": {
      "types": "./dist/rsdkv5/rsdkv5.options.d.ts",
      "import": "./dist/rsdkv5/rsdkv5.options.js"
    },
    "./manifest": "./dist/manifest.json"
  },
  "files": [
    "dist/rsdkv5/",
    "!dist/rsdkv5/*.data",
    "!dist/rsdkv5/*.rsdk",
    "dist/manifest.json",
    "src/rsdkv5.manifest.ts",
    "src/rsdkv5.options.ts",
    "src/rsdkv5.sdk.ts",
    "README.md"
  ],
  "comment:scripts": "Build logic lives in the Makefile, not here (make build / build-sdk / build-wasm / preview).",
  "scripts": {},
  "peerDependencies": {
    "@wasm-gaming/engine-specs": "*"
  },
  "peerDependenciesMeta": {
    "@wasm-gaming/engine-specs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@wasm-gaming/engine-specs": "^0.1.0",
    "typescript": "^5.5.0"
  },
  "engineContract": "https://github.com/wasm-gaming/engine-specs",
  "license": "MIT"
}
